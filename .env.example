NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://to5:password@localhost:5432/to5delivery
JWT_SECRET=replace-with-openssl-rand-base64-48-min-32-chars
# Comma-separated for multiple dev origins, e.g. https://localhost:5173,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Set to false in production if accounts are created only by admins (default: open registration)
# ALLOW_REGISTER=false

# Google Places (New) — server only; used by POST /api/places/search-text (not exposed to the browser)
# GOOGLE_PLACES_API_KEY=

# One-time local admin (use with: npm run seed:admin)
# ADMIN_EMAIL=admin@local.test
# ADMIN_PASSWORD=change-me-min-8-chars
# ADMIN_NAME=Admin
